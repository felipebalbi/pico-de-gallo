# Enforce LF line endings on all text files.
#
# Without this, a contributor on Windows can silently introduce CRLF
# line endings, which trip shellcheck/actionlint, break here-docs in
# CI shell scripts, and produce noisy whole-file diffs.
#
# `text=auto` lets git detect text vs binary; `eol=lf` forces LF on
# checkin and on checkout regardless of `core.autocrlf`. Run
# `dos2unix <file>` on any file you create on Windows before committing
# (or just rely on git to renormalize on commit).

* text=auto eol=lf

# --- Explicit text overrides (in case auto-detect gets it wrong) -----
*.rs            text eol=lf
*.toml          text eol=lf
*.md            text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.json          text eol=lf
*.sh            text eol=lf
*.py            text eol=lf
*.h             text eol=lf
*.c             text eol=lf
*.lock          text eol=lf

# --- KiCad project files (S-expressions / JSON, text) ---------------
#
# KiCad's PCB, schematic, project, symbol, footprint, design-rules,
# and project-local files are line-oriented text (S-expressions for
# .kicad_pcb/.kicad_sch/.kicad_sym/.kicad_mod/.kicad_dru, JSON for
# .kicad_pro/.kicad_prl). Treating them as text gives us real diffs,
# three-way merge, and `git blame` on hardware changes. Force LF on
# checkin and checkout so a contributor with core.autocrlf=true on
# Windows doesn't trigger a whole-file rewrite the next time KiCad
# saves the project.
*.kicad_sch     text eol=lf
*.kicad_pcb     text eol=lf
*.kicad_pro     text eol=lf
*.kicad_sym     text eol=lf
*.kicad_mod     text eol=lf
*.kicad_dru     text eol=lf
*.kicad_prl     text eol=lf

# --- Binary files (never touch line endings) -------------------------
*.png           binary
*.jpg           binary
*.jpeg          binary
*.gif           binary
*.ico           binary
*.pdf           binary
*.uf2           binary
*.bin           binary
*.elf           binary
*.so            binary
*.dylib         binary
*.dll           binary
*.a             binary
*.lib           binary
*.zip           binary
*.tar           binary
*.gz            binary
*.whl           binary
*.step          binary
*.stp           binary
*.stl           binary

# FreeCAD project files are zipped XML — definitely binary.
*.FCStd         binary
*.FCStd1        binary
*.FCBak         binary
